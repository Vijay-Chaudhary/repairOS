# Django
DJANGO_SETTINGS_MODULE=config.settings.local
SECRET_KEY=your-very-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Master database (django-environ DB URL format)
MASTER_DATABASE_URL=postgres://postgres:postgres@localhost:5432/repaiross_master

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT signing key (use a separate strong key in production)
JWT_SIGNING_KEY=your-jwt-signing-key-change-in-production

# Tenant credential encryption key (Fernet key — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
TENANT_CRED_ENCRYPTION_KEY=your-fernet-key-here

# API domain — subdomains are {slug}.API_DOMAIN
API_DOMAIN=api.repaiross.app

# CORS — comma-separated origins allowed in local dev
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# OTP (MSG91 — leave blank in local dev to use console backend)
MSG91_AUTH_KEY=
MSG91_SENDER_ID=REPROS

# WhatsApp (Meta Cloud API)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# AWS (leave blank in local dev)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=ap-south-1
