# ─────────────────────────────────────────────────────────────────────────────
# RepairOS — local dev environment variables
# cp .env.example .env  (never commit .env)
#
# Variable sources:
#   docker-compose.yml  reads these via env_file: .env
#   Django              reads from container environment (set by compose)
#   Frontend            NEXT_PUBLIC_* vars only
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Superuser (postgres) password — used by Docker init only, not by the app
POSTGRES_SUPERUSER_PASSWORD=localdevSUPER

# Master DB app user — Django connects here DIRECTLY (bypasses PgBouncer so
# CREATE DATABASE DDL in create_tenant works; PgBouncer transaction mode
# cannot handle session-level autocommit).
MASTER_DB_PASSWORD=masterLocal99
MASTER_DATABASE_URL=postgres://repaiross_master_user:masterLocal99@postgres:5432/repaiross_master

# ── PgBouncer ─────────────────────────────────────────────────────────────────
# Admin console password  → psql -h localhost -p 6432 -U pgbouncer_admin pgbouncer
PGBOUNCER_ADMIN_PASSWORD=pgbAdmin99
# Auth-query user password (reads pg_shadow; never used for app connections)
PGBOUNCER_AUTH_PASSWORD=pgbAuth99

# Tenant DB host — stored in master.tenant_databases for every provisioned tenant.
# All tenant queries route through PgBouncer (transaction mode), not postgres directly.
TENANT_DB_HOST=pgbouncer

# ── Redis ─────────────────────────────────────────────────────────────────────
# Segmented logical DBs: /0 Celery, /1 Django cache, /2 Channels. All three are
# required — the cache (login/OTP) and Channels fall back to localhost otherwise.
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/1
REDIS_CHANNELS_URL=redis://redis:6379/2

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.local
# Generate: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=CHANGE-ME-local-dev-secret-key-at-least-50-chars-long-replace
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# JWT — keep separate from SECRET_KEY so rotation doesn't invalidate all tokens
# Generate: python -c "import secrets; print(secrets.token_urlsafe(50))"
JWT_SIGNING_KEY=CHANGE-ME-local-jwt-key-replace-with-50-char-random-string

# Tenant credential encryption (Fernet symmetric key)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TENANT_CRED_ENCRYPTION_KEY=GENERATE-ME-run-command-above-and-paste-here

# Domain (used for CORS + subdomain routing)
API_DOMAIN=localhost:8000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── MinIO (local S3 replacement) ──────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
# Django / boto3 see these — point at MinIO, not AWS
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
AWS_STORAGE_BUCKET_NAME=repaiross-local
AWS_S3_REGION_NAME=us-east-1
# Internal URL (backend → minio container)
AWS_S3_ENDPOINT_URL=http://minio:9000
# External URL (browser presigned URLs — must be reachable from the host)
AWS_S3_PUBLIC_URL=http://localhost:9000

# ── Email (Mailpit local SMTP) ────────────────────────────────────────────────
EMAIL_HOST=mailpit
EMAIL_PORT=1025
EMAIL_USE_TLS=False
DEFAULT_FROM_EMAIL=noreply@repaiross.local
# Web UI at http://localhost:8025

# ── External API stubs ────────────────────────────────────────────────────────
# MSG91 — leave blank; Django EMAIL_BACKEND=console sends OTPs to stdout
MSG91_AUTH_KEY=
MSG91_SENDER_ID=REPROS

# WhatsApp (Meta Cloud API) — disabled locally
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Razorpay — sandbox test keys (safe to use; no real charges)
RAZORPAY_KEY_ID=rzp_test_REPLACE_WITH_SANDBOX_KEY
RAZORPAY_KEY_SECRET=REPLACE_WITH_SANDBOX_SECRET

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
# NEXT_PUBLIC_* vars are inlined at build time — keep them pointing at localhost
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_MINIO_URL=http://localhost:9000
