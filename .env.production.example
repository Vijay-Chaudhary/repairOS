# ─────────────────────────────────────────────────────────────────────────────
# RepairOS — PRODUCTION environment (Hostinger VPS)
#
#   cp .env.production.example .env     # on the server, in the deploy dir
#   chmod 600 .env                      # never world-readable, never committed
#
# Generate every secret freshly — do NOT reuse the local-dev values.
# Read by docker-compose.prod.yml (env_file) and by Django at runtime.
# ─────────────────────────────────────────────────────────────────────────────

# ── Container images (overwritten by the CI deploy step each release) ─────────
# CI exports these to the exact immutable SHA tag before `compose pull`.
BACKEND_IMAGE=ghcr.io/vijay-chaudhary/repaiross-backend:latest
FRONTEND_IMAGE=ghcr.io/vijay-chaudhary/repaiross-frontend:latest

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# openssl rand -base64 24
POSTGRES_SUPERUSER_PASSWORD=CHANGE-ME-strong-random
MASTER_DB_PASSWORD=CHANGE-ME-strong-random
MASTER_DATABASE_URL=postgres://repaiross_master_user:CHANGE-ME-strong-random@postgres:5432/repaiross_master

# ── PgBouncer ─────────────────────────────────────────────────────────────────
PGBOUNCER_ADMIN_PASSWORD=CHANGE-ME-strong-random
PGBOUNCER_AUTH_PASSWORD=CHANGE-ME-strong-random
# Tenant queries route through PgBouncer (transaction mode).
TENANT_DB_HOST=pgbouncer

# ── Redis ─────────────────────────────────────────────────────────────────────
# openssl rand -base64 24  — must match the password embedded in the URLs below.
REDIS_PASSWORD=CHANGE-ME-strong-random
# Segmented logical DBs: /0 broker+results, /1 cache, /2 channels. Note the
# leading ':' before the password (no username) in the redis:// URL.
REDIS_URL=redis://:CHANGE-ME-strong-random@redis:6379/0
REDIS_CACHE_URL=redis://:CHANGE-ME-strong-random@redis:6379/1
REDIS_CHANNELS_URL=redis://:CHANGE-ME-strong-random@redis:6379/2

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.production
DEBUG=False
# python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=CHANGE-ME-50-char-random
JWT_SIGNING_KEY=CHANGE-ME-50-char-random
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TENANT_CRED_ENCRYPTION_KEY=CHANGE-ME-fernet-key

# Comma-separated. Include the apex API host, the wildcard tenant API host, and
# the internal service name so container-to-container health checks pass.
ALLOWED_HOSTS=api.repaiross.app,.api.repaiross.app,app.repaiross.app,backend,localhost
API_DOMAIN=api.repaiross.app

# Origins allowed to call the API from the browser (the PWA).
CORS_ALLOWED_ORIGINS=https://app.repaiross.app

# ── Object storage (MinIO self-hosted, or real AWS S3) ────────────────────────
# USE_S3=True routes Django media to the S3 API. For AWS later: set USE_S3=True,
# drop AWS_S3_ENDPOINT_URL, set the real bucket/region/keys + a CloudFront/S3
# AWS_S3_CUSTOM_DOMAIN. No code change.
USE_S3=True
MINIO_ROOT_USER=repaiross
MINIO_ROOT_PASSWORD=CHANGE-ME-strong-random
AWS_ACCESS_KEY_ID=repaiross
AWS_SECRET_ACCESS_KEY=CHANGE-ME-strong-random
AWS_STORAGE_BUCKET_NAME=repaiross-prod
AWS_S3_REGION_NAME=us-east-1
# Internal URL (backend → minio container). Blank/unset for real AWS S3.
AWS_S3_ENDPOINT_URL=http://minio:9000
# Public host browsers use for media URLs. nginx proxies media.repaiross.app →
# MinIO, so the bucket must be in the path. For AWS S3 use the CloudFront/S3 host.
AWS_S3_CUSTOM_DOMAIN=media.repaiross.app/repaiross-prod
# True = signed (private) URLs; False = public-read URLs.
AWS_QUERYSTRING_AUTH=False

# ── Email (real SMTP — e.g. Hostinger / SES / Postmark) ───────────────────────
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@repaiross.app
EMAIL_HOST_PASSWORD=CHANGE-ME
DEFAULT_FROM_EMAIL=noreply@repaiross.app

# ── External integrations ─────────────────────────────────────────────────────
MSG91_AUTH_KEY=CHANGE-ME
MSG91_SENDER_ID=REPROS
WHATSAPP_TOKEN=CHANGE-ME
WHATSAPP_PHONE_NUMBER_ID=CHANGE-ME
RAZORPAY_KEY_ID=rzp_live_CHANGE-ME
RAZORPAY_KEY_SECRET=CHANGE-ME

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Frontend (baked into the image at build time by CI — listed for reference) ─
# These are passed as Docker build args in the deploy workflow, NOT read here.
# NEXT_PUBLIC_API_URL=https://api.repaiross.app
# NEXT_PUBLIC_WS_URL=wss://api.repaiross.app
# NEXT_PUBLIC_MINIO_URL=https://media.repaiross.app
